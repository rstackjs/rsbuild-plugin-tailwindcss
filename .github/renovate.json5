{
	$schema: 'https://docs.renovatebot.com/renovate-schema.json',
	extends: [
		'config:recommended',
		'schedule:monthly',
		'group:allNonMajor',
	],
	baseBranchPatterns: ['main', 'v4'],
	rangeStrategy: 'bump',
	packageRules: [
		{
			matchDepTypes: [
				'peerDependencies',
			],
			enabled: false,
		},
	],
}
